# Apoio fora do índice dos buscadores. O que não sobe no deploy responde 404;
# o que sobe como exceção (README, docs/DESIGN.md, previews/preview-email-
# entrega.html) fica coberto por estas regras.
/docs/*
  X-Robots-Tag: noindex

/previews/*
  X-Robots-Tag: noindex

/mockups-antigos/*
  X-Robots-Tag: noindex

/README.md
  X-Robots-Tag: noindex

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://w.soundcloud.com https://widget.sndcdn.com https://sdk.mercadopago.com https://http2.mlstatic.com https://cdn.jsdelivr.net https://fonts.googleapis.com https://www.googletagmanager.com https://cdn.emailjs.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://http2.mlstatic.com; font-src 'self' data: https://fonts.gstatic.com https://http2.mlstatic.com; img-src 'self' data: https:; frame-src https://w.soundcloud.com https://*.mercadopago.com https://*.mercadolibre.com; connect-src 'self' https://api.mercadopago.com https://*.mercadopago.com https://*.mercadolibre.com https://www.mercadolibre.com https://http2.mlstatic.com https://api.emailjs.com https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; worker-src blob:; frame-ancestors 'none';
